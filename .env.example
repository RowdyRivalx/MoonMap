# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/dao_intelligence"

# ─── Auth (NextAuth v5) ──────────────────────────────────────────────────────
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# ─── Solana ──────────────────────────────────────────────────────────────────
# Optional: custom RPC (default uses public endpoint, which is rate-limited)
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"

# Helius API key — STRONGLY recommended for reliable NFT lookups
# Free tier at helius.dev handles 100k requests/month
HELIUS_API_KEY="your-helius-api-key"

# ─── CoinGecko API ───────────────────────────────────────────────────────────
COINGECKO_API_KEY="CG-..."

# ─── CryptoPanic (news + sentiment) ─────────────────────────────────────────
CRYPTOPANIC_API_KEY="..."

# ─── App URL ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
